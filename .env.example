# Copy to your hosting provider's environment settings. Never commit real values.
SPRING_PROFILES_ACTIVE=supabase
PORT=8080

# Supabase Dashboard -> Connect -> Session pooler (port 5432) or Direct connection.
# Use a JDBC URL, not the raw postgres:// URL copied for psql.
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF
SPRING_DATASOURCE_PASSWORD=REPLACE_WITH_SUPABASE_DATABASE_PASSWORD

# Bootstrap an empty project with JPA. Change to validate after the first deploy.
JPA_DDL_AUTO=update
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1

# Generate separate production secrets. Do not reuse the local defaults.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
APP_CRYPTO_AES_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# Optional AI advisor. Leave empty to disable the external advisor.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Exact public URL of the deployed Angular frontend.
CORS_ORIGIN=https://YOUR-FRONTEND-DOMAIN.example
